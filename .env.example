# --- Gemini ---
GOOGLE_API_KEY=your_gemini_api_key_here
MODEL_NAME=gemini-2.5-flash
MAX_RETRIES=3
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Clerk Auth ---
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks

# --- JWT (開発モードフォールバック用) ---
# openssl rand -hex 32  で生成推奨
JWT_SECRET=change_me_to_a_long_random_hex_string
JWT_EXPIRES_HOURS=168

# --- Tickets ---
INITIAL_FREE_TICKETS=3
# 外部チケット購入サイトURL (ユーザーがリダイレクトされる先)
TICKET_SHOP_URL=https://example.com/debate-arena-tickets

# --- Webhook (外部購入サイトからの通知) ---
# 購入サイトと共有する HMAC-SHA256 署名用シークレット
WEBHOOK_SECRET=change_me_to_a_long_random_hex_string

# --- Frontend (Viteから読む) ---
VITE_API_BASE=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
VITE_TICKET_SHOP_URL=https://example.com/debate-arena-tickets
